{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://traffic.analysis.local/schemas/learning-episode.schema.json",
  "title": "Traffic Analysis Platform Learning Episode",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "task_id",
    "subject",
    "versions",
    "observation",
    "selected_action",
    "gates",
    "reward",
    "critics",
    "main_thread_decision",
    "production",
    "learning_status",
    "evidence"
  ],
  "properties": {
    "schema_version": {
      "const": "2026-07-12.v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id", "risk"],
      "properties": {
        "type": {
          "enum": ["page", "tab", "overlay", "business-flow", "performance"]
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "route": {
          "type": "string"
        },
        "risk": {
          "enum": ["low", "medium", "high", "critical"]
        }
      }
    },
    "versions": {
      "type": "object",
      "required": ["code", "evaluator", "policy"],
      "properties": {
        "code": {"type": "string"},
        "frontend_image": {"type": "string"},
        "backend_image": {"type": "string"},
        "evaluator": {"type": "string"},
        "policy": {"type": "string"}
      },
      "additionalProperties": false
    },
    "observation": {
      "type": "object",
      "required": ["business", "function", "visual", "quality", "production", "data_sources"],
      "properties": {
        "business": {"type": "object"},
        "function": {"type": "object"},
        "visual": {"type": "object"},
        "quality": {"type": "object"},
        "production": {"type": "object"},
        "data_sources": {
          "type": "array",
          "items": {"type": "string"},
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "action_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "summary", "allowed_paths"],
        "properties": {
          "id": {"type": "string"},
          "type": {"enum": ["product", "ui", "function", "data", "test", "performance"]},
          "summary": {"type": "string"},
          "allowed_paths": {
            "type": "array",
            "items": {"type": "string"}
          }
        },
        "additionalProperties": false
      },
      "maxItems": 3
    },
    "selected_action": {
      "type": "object",
      "required": ["id", "reason", "change_intent"],
      "properties": {
        "id": {"type": "string"},
        "reason": {"type": "string"},
        "change_intent": {
          "type": "array",
          "items": {"type": "string"},
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "gates": {
      "type": "object",
      "required": ["all_passed", "results"],
      "properties": {
        "all_passed": {"type": "boolean"},
        "results": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "status", "evidence"],
            "properties": {
              "id": {"type": "string"},
              "status": {"enum": ["pass", "fail", "blocked", "human-gate"]},
              "evidence": {
                "type": "array",
                "items": {"type": "string"}
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "reward": {
      "type": "object",
      "required": ["eligible", "total", "dimensions", "penalties", "confidence"],
      "properties": {
        "eligible": {"type": "boolean"},
        "total": {"type": ["number", "null"], "minimum": 0, "maximum": 100},
        "dimensions": {
          "type": "object",
          "required": ["business", "function", "quality", "visual", "performance", "maintainability"],
          "properties": {
            "business": {"type": "number", "minimum": 0, "maximum": 100},
            "function": {"type": "number", "minimum": 0, "maximum": 100},
            "quality": {"type": "number", "minimum": 0, "maximum": 100},
            "visual": {"type": "number", "minimum": 0, "maximum": 100},
            "performance": {"type": "number", "minimum": 0, "maximum": 100},
            "maintainability": {"type": "number", "minimum": 0, "maximum": 100}
          },
          "additionalProperties": false
        },
        "penalties": {
          "type": "object",
          "required": ["regression", "cost", "uncertainty"],
          "properties": {
            "regression": {"type": "number", "minimum": 0},
            "cost": {"type": "number", "minimum": 0},
            "uncertainty": {"type": "number", "minimum": 0}
          },
          "additionalProperties": false
        },
        "confidence": {"type": "number", "minimum": 0, "maximum": 1}
      },
      "additionalProperties": false
    },
    "critics": {
      "type": "object",
      "required": ["page_logic", "page_layout", "design", "business", "quality", "performance"],
      "properties": {
        "page_logic": {"$ref": "#/$defs/critic"},
        "page_layout": {"$ref": "#/$defs/critic"},
        "design": {"$ref": "#/$defs/critic"},
        "business": {"$ref": "#/$defs/critic"},
        "quality": {"$ref": "#/$defs/critic"},
        "performance": {"$ref": "#/$defs/critic"}
      },
      "additionalProperties": false
    },
    "main_thread_decision": {
      "type": "object",
      "required": ["decision", "finding_decisions", "reason"],
      "properties": {
        "decision": {"enum": ["accept", "repair", "rollback", "human-gate"]},
        "finding_decisions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["finding_id", "source_critic", "decision", "reason", "evidence"],
            "properties": {
              "finding_id": {"type": "string"},
              "source_critic": {"enum": ["page_logic", "page_layout", "design", "business", "quality", "performance"]},
              "decision": {"enum": ["accepted", "rejected", "deferred"]},
              "reason": {"type": "string"},
              "evidence": {
                "type": "array",
                "items": {"type": "string"},
                "minItems": 1
              }
            },
            "additionalProperties": false
          }
        },
        "reason": {"type": "string"}
      },
      "additionalProperties": false
    },
    "production": {
      "type": "object",
      "required": ["status", "stable_window", "rollback_verified"],
      "properties": {
        "status": {"enum": ["not-deployed", "canary", "stable", "degraded", "rolled-back"]},
        "stable_window": {"type": "string"},
        "rollback_verified": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "learning_status": {
      "enum": ["ineligible", "neutral", "negative", "positive"]
    },
    "evaluation": {
      "type": "object",
      "required": [
        "evaluated_at",
        "policy_version",
        "hard_gates_passed",
        "missing_hard_gates",
        "non_pass_hard_gates",
        "weighted_reward_before_penalties",
        "penalty_total"
      ],
      "properties": {
        "evaluated_at": {"type": "string", "minLength": 1},
        "policy_version": {"type": "string", "minLength": 1},
        "hard_gates_passed": {"type": "boolean"},
        "missing_hard_gates": {
          "type": "array",
          "items": {"type": "string"}
        },
        "non_pass_hard_gates": {
          "type": "array",
          "items": {"type": "string"}
        },
        "weighted_reward_before_penalties": {"type": "number", "minimum": 0, "maximum": 100},
        "penalty_total": {"type": "number", "minimum": 0}
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "path", "checksum"],
        "properties": {
          "type": {"type": "string"},
          "path": {"type": "string"},
          "checksum": {"type": "string"}
        },
        "additionalProperties": false
      },
      "minItems": 1
    }
  },
  "$defs": {
    "critic": {
      "type": "object",
      "required": ["verdict", "findings", "evidence"],
      "properties": {
        "verdict": {"enum": ["pass", "fail", "uncertain"]},
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "severity", "summary"],
            "properties": {
              "id": {"type": "string"},
              "severity": {"enum": ["P0", "P1", "P2", "P3"]},
              "summary": {"type": "string"}
            },
            "additionalProperties": false
          }
        },
        "evidence": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": false
    }
  }
}
