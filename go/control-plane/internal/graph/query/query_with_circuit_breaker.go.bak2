// FindPaths 查找路径（带熔断保护）
func (q *GraphQueryWithCircuitBreaker) FindPaths(
	ctx context.Context,
	tenantID, sourceIP, targetIP string,
	maxHops int,
	startTime, endTime int64,
	runID string,
) ([]Path, error) {
	var result []Path
	var err error

	cbErr := q.circuitBreaker.Execute(ctx, func() error {
		result, err = q.GraphQuery.FindPaths(ctx, tenantID, sourceIP, targetIP, maxHops, startTime, endTime, runID)
		return err
	})

	if cbErr != nil {
		if isCircuitBreakerError(cbErr) {
			atomic.AddInt64(&q.rejectedRequests, 1)
			q.logger.Warn("Circuit breaker triggered for FindPaths",
				zap.String("tenant_id", tenantID),
				zap.String("source", sourceIP),
				zap.String("target", targetIP),
				zap.Int("max_hops", maxHops),
				zap.Error(cbErr))

			return []Path{}, cbErr
		}
		return nil, cbErr
