package query

import (
	"context"
	"sync/atomic"
	"time"

	"go.uber.org/zap"

	"github.com/1144160159/traffic-analysis-platform/go/control-plane/internal/common/storage"
	"github.com/1144160159/traffic-analysis-platform/go/control-plane/internal/common/utils"
	"github.com/1144160159/traffic-analysis-platform/go/control-plane/internal/graph/cache"
	"github.com/1144160159/traffic-analysis-platform/go/control-plane/internal/graph/config"
)

// GraphQueryWithCircuitBreaker 带熔断器的图查询引擎（包装器）
type GraphQueryCB struct {
	*GraphQuery
	circuitBreaker *utils.CircuitBreaker
	logger         *zap.Logger

	// 降级统计
	degradedRequests int64
	rejectedRequests int64
}

// NewGraphQueryCB 创建带熔断器的图查询引擎
func NewGraphQueryCB(
	client *storage.ClickHouseClient,
	cache *cache.GraphCache,
	cfg config.QueryConfig,
	circuitBreaker *utils.CircuitBreaker,
	logger *zap.Logger,
) *GraphQueryWithCircuitBreaker {
	return &GraphQueryWithCircuitBreaker{
		GraphQuery:     NewGraphQuery(client, cache, cfg, logger),
		circuitBreaker: circuitBreaker,
		logger:         logger,
	}
}

// ==================== 核心查询方法（带熔断保护） ====================

// Explore 图探索（带熔断保护）
func (q *GraphQueryWithCircuitBreaker) Explore(
	ctx context.Context,
	tenantID, centerIP string,
	depth int,
	startTime, endTime int64,
	runID string,
) (*Graph, error) {
	var result *Graph
	var err error

	cbErr := q.circuitBreaker.Execute(ctx, func() error {
		result, err = q.GraphQuery.Explore(ctx, tenantID, centerIP, depth, startTime, endTime, runID)
		return err
	})

	if cbErr != nil {
		if isCircuitBreakerError(cbErr) {
			atomic.AddInt64(&q.rejectedRequests, 1)
			q.logger.Warn("Circuit breaker triggered for Explore",
				zap.String("tenant_id", tenantID),
				zap.String("center_ip", centerIP),
				zap.Int("depth", depth),
				zap.String("run_id", runID),
				zap.String("cb_state", q.circuitBreaker.GetState().String()),
				zap.Error(cbErr))

			// 修复：返回带降级标记的空图
			return q.buildDegradedGraph(centerIP, "circuit_breaker_open"), cbErr
		}
		return nil, cbErr
	}

	return result, nil
}

// BatchExplore 批量图探索（带熔断保护）
func (q *GraphQueryWithCircuitBreaker) BatchExplore(
	ctx context.Context,
	tenantID string,
	centerIPs []string,
	depth int,
	startTime, endTime int64,
	runID string,
) (*Graph, error) {
	var result *Graph
	var err error

	cbErr := q.circuitBreaker.Execute(ctx, func() error {
		result, err = q.GraphQuery.BatchExplore(ctx, tenantID, centerIPs, depth, startTime, endTime, runID)
		return err
	})

	if cbErr != nil {
		if isCircuitBreakerError(cbErr) {
			atomic.AddInt64(&q.rejectedRequests, 1)
			q.logger.Warn("Circuit breaker triggered for BatchExplore",
				zap.String("tenant_id", tenantID),
				zap.Strings("center_ips", centerIPs),
				zap.Int("depth", depth),
				zap.String("run_id", runID),
				zap.Error(cbErr))

			return q.buildDegradedGraphForBatch(centerIPs, "circuit_breaker_open"), cbErr
		}
		return nil, cbErr
	}

	return result, nil
}

// GetNeighbors 获取邻居列表（带熔断保护）- 修复：新增
func (q *GraphQueryWithCircuitBreaker) GetNeighbors(
	ctx context.Context,
	tenantID, entityID string,
	startTime, endTime int64,
	runID string,
	limit int,
) ([]*GraphNode, error) {
	var result []*GraphNode
	var err error

	cbErr := q.circuitBreaker.Execute(ctx, func() error {
		result, err = q.GraphQuery.GetNeighbors(ctx, tenantID, entityID, startTime, endTime, runID, limit)
		return err
	})

	if cbErr != nil {
		if isCircuitBreakerError(cbErr) {
			atomic.AddInt64(&q.rejectedRequests, 1)
			q.logger.Warn("Circuit breaker triggered for GetNeighbors",
				zap.String("tenant_id", tenantID),
				zap.String("entity_id", entityID),
				zap.Error(cbErr))

			return []*GraphNode{}, cbErr
		}
		return nil, cbErr
	}

	return result, nil
}

// GetEntityDetails 获取实体详情（带熔断保护）
func (q *GraphQueryWithCircuitBreaker) GetEntityDetails(
	ctx context.Context,
	tenantID, entityID, entityType string,
	startTime, endTime int64,
	runID string,
) (map[string]interface{}, error) {
	var result map[string]interface{}
	var err error

	cbErr := q.circuitBreaker.Execute(ctx, func() error {
		result, err = q.GraphQuery.GetEntityDetails(ctx, tenantID, entityID, entityType, startTime, endTime, runID)
		return err
	})

	if cbErr != nil {
		if isCircuitBreakerError(cbErr) {
			atomic.AddInt64(&q.rejectedRequests, 1)
			q.logger.Warn("Circuit breaker triggered for GetEntityDetails",
				zap.String("tenant_id", tenantID),
				zap.String("entity_id", entityID),
				zap.String("entity_type", entityType),
				zap.Error(cbErr))

			// 修复：返回带降级标记的响应
			return map[string]interface{}{
				"entity_id":   entityID,
				"entity_type": entityType,
				"degraded":    true,
				"reason":      "circuit_breaker_open",
				"message":     "Service temporarily unavailable, please retry later",
			}, cbErr
		}
		return nil, cbErr
	}

	return result, nil
}

