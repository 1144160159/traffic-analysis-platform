	return result, nil
}

// GetStats 获取统计信息（带熔断保护）
func (q *GraphQueryWithCircuitBreaker) GetStats(
	ctx context.Context,
	tenantID string,
	startTime, endTime int64,
	runID string,
) (map[string]interface{}, error) {
	var result map[string]interface{}
	var err error

	cbErr := q.circuitBreaker.Execute(ctx, func() error {
		result, err = q.GraphQuery.GetStats(ctx, tenantID, startTime, endTime, runID)
		return err
	})

	if cbErr != nil {
		if isCircuitBreakerError(cbErr) {
			atomic.AddInt64(&q.rejectedRequests, 1)
			q.logger.Warn("Circuit breaker triggered for GetStats",
				zap.String("tenant_id", tenantID),
				zap.String("run_id", runID),
				zap.Error(cbErr))

			// 修复：返回带降级标记的响应
			return map[string]interface{}{
				"degraded": true,
				"reason":   "circuit_breaker_open",
				"message":  "Service temporarily unavailable, please retry later",
				"time_range": map[string]interface{}{
					"start_time": startTime,
					"end_time":   endTime,
				},
				"run_id": runID,
			}, cbErr
		}
		return nil, cbErr
	}

	return result, nil
}

// ==================== 降级响应构建 ====================

// buildDegradedGraph 构建降级的图响应
func (q *GraphQueryWithCircuitBreaker) buildDegradedGraph(centerIP, reason string) *Graph {
	atomic.AddInt64(&q.degradedRequests, 1)

	return &Graph{
		Nodes: []*GraphNode{
			{
				IP:   centerIP,
				Type: "ip",
				Meta: map[string]interface{}{
					"is_center": true,
					"degraded":  true,
					"reason":    reason,
				},
			},
		},
		Edges:     []*GraphEdge{},
		Truncated: true,
	}
}

// buildDegradedGraphForBatch 构建批量探索的降级响应
func (q *GraphQueryWithCircuitBreaker) buildDegradedGraphForBatch(centerIPs []string, reason string) *Graph {
	atomic.AddInt64(&q.degradedRequests, 1)

	nodes := make([]*GraphNode, 0, len(centerIPs))
	for i, ip := range centerIPs {
		nodes = append(nodes, &GraphNode{
			IP:   ip,
			Type: "ip",
			Meta: map[string]interface{}{
				"is_center": i == 0,
				"degraded":  true,
				"reason":    reason,
			},
		})
	}

	return &Graph{
		Nodes:     nodes,
		Edges:     []*GraphEdge{},
		Truncated: true,
	}
}

// ==================== 健康检查和指标 ====================

// Ping 检查连接（带熔断保护）
func (q *GraphQueryWithCircuitBreaker) Ping(ctx context.Context) error {
	return q.circuitBreaker.Execute(ctx, func() error {
		return q.GraphQuery.Ping(ctx)
	})
}

// GetCircuitBreakerState 获取熔断器状态
func (q *GraphQueryWithCircuitBreaker) GetCircuitBreakerState() utils.State {
	return q.circuitBreaker.GetState()
}

// GetCircuitBreakerMetrics 获取熔断器指标
func (q *GraphQueryWithCircuitBreaker) GetCircuitBreakerMetrics() utils.Metrics {
	return q.circuitBreaker.GetMetrics()
}

// GetDegradedStats 获取降级统计
func (q *GraphQueryWithCircuitBreaker) GetDegradedStats() map[string]int64 {
	return map[string]int64{
		"degraded_requests": atomic.LoadInt64(&q.degradedRequests),
		"rejected_requests": atomic.LoadInt64(&q.rejectedRequests),
	}
}

// GetCombinedMetrics 获取组合指标（查询指标 + 熔断器指标）
func (q *GraphQueryWithCircuitBreaker) GetCombinedMetrics() map[string]interface{} {
	queryMetrics := q.GraphQuery.GetMetrics()
	cbMetrics := q.circuitBreaker.GetMetrics()

	return map[string]interface{}{
		"query": map[string]interface{}{
			"total_queries":      queryMetrics.TotalQueries,
			"failed_queries":     queryMetrics.FailedQueries,
			"timeout_queries":    queryMetrics.TimeoutQueries,
			"cache_hits":         queryMetrics.CacheHits,
			"cache_misses":       queryMetrics.CacheMisses,
			"avg_query_duration": time.Duration(queryMetrics.AvgQueryDuration).String(),
			"cache_hit_rate":     calculateHitRate(queryMetrics.CacheHits, queryMetrics.CacheMisses),
		},
		"circuit_breaker": map[string]interface{}{
			"state":             cbMetrics.State.String(),
			"total_requests":    cbMetrics.TotalRequests,
			"failed_requests":   cbMetrics.FailedRequests,
			"rejected_requests": cbMetrics.RejectedRequests,
			"success_rate":      cbMetrics.SuccessRate(),
			"failure_rate":      cbMetrics.FailureRate(),
		},
		"degradation": map[string]interface{}{
			"degraded_requests": atomic.LoadInt64(&q.degradedRequests),
			"rejected_requests": atomic.LoadInt64(&q.rejectedRequests),
		},
	}
}

// Close 关闭资源
func (q *GraphQueryWithCircuitBreaker) Close() error {
	q.logger.Info("Closing graph query with circuit breaker",
		zap.String("cb_state", q.circuitBreaker.GetState().String()),
		zap.Int64("degraded_requests", atomic.LoadInt64(&q.degradedRequests)),
		zap.Int64("rejected_requests", atomic.LoadInt64(&q.rejectedRequests)))

	return q.GraphQuery.Close()
}

// ==================== 辅助函数 ====================

// isCircuitBreakerError 判断是否是熔断器错误
func isCircuitBreakerError(err error) bool {
	if err == nil {
		return false
	}
	return err == utils.ErrCircuitOpen || err == utils.ErrTooManyRequests
}

// calculateHitRate 计算缓存命中率
func calculateHitRate(hits, misses int64) float64 {
	total := hits + misses
	if total == 0 {
		return 0.0
	}
	return float64(hits) / float64(total) * 100
}
