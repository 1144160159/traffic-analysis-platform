FROM golang:1.23-alpine AS builder

RUN apk add --no-cache git ca-certificates

WORKDIR /workspace
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /ingest-gateway ./cmd/ingest-gateway

FROM alpine:3.19
RUN apk --no-cache add ca-certificates tzdata
COPY --from=builder /ingest-gateway /usr/local/bin/

RUN adduser -D -u 1000 appuser
USER appuser

EXPOSE 9090 9091
ENTRYPOINT ["/usr/local/bin/ingest-gateway"]