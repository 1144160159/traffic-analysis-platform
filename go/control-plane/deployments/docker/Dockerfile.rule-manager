FROM golang:1.24-alpine AS builder

RUN apk add --no-cache git ca-certificates

WORKDIR /workspace
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /rule-manager ./cmd/rule-manager

FROM alpine:3.19
RUN apk --no-cache add ca-certificates tzdata
COPY --from=builder /rule-manager /usr/local/bin/

RUN adduser -D -u 1000 appuser
USER appuser

EXPOSE 8082
ENTRYPOINT ["/usr/local/bin/rule-manager"]
