################################################################################
# FILE PATH: control-plane/.env.example
# Auth Service 环境变量配置示例
################################################################################

#------------------------------------------------------------------------------
# 日志配置
#------------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
ENVIRONMENT=development

#------------------------------------------------------------------------------
# 服务配置
#------------------------------------------------------------------------------
SERVER_LISTEN_ADDR=:8080
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s
SERVER_IDLE_TIMEOUT=120s
SERVER_READ_HEADER_TIMEOUT=5s
SERVER_MAX_HEADER_BYTES=1048576
SERVER_SHUTDOWN_TIMEOUT=15s

# TLS 配置（可选，用于 mTLS）
SERVER_TLS_ENABLED=false
SERVER_TLS_CERT_FILE=/path/to/server.crt
SERVER_TLS_KEY_FILE=/path/to/server.key
SERVER_TLS_CA_FILE=/path/to/ca.crt

#------------------------------------------------------------------------------
# PostgreSQL 配置
#------------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=traffic
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=your-password-here
POSTGRES_SSL_MODE=disable
POSTGRES_MAX_OPEN_CONNS=25
POSTGRES_MAX_IDLE_CONNS=5
POSTGRES_CONN_MAX_LIFETIME=1h
POSTGRES_CONN_MAX_IDLE_TIME=30m
POSTGRES_CONNECT_TIMEOUT=10

#------------------------------------------------------------------------------
# Redis 配置
#------------------------------------------------------------------------------
# 单机模式
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# 或集群模式（与 REDIS_ADDR 二选一）
# REDIS_ADDRS=redis1:6379,redis2:6379,redis3:6379

# 连接池配置
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=5
REDIS_MAX_RETRIES=3
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s
REDIS_POOL_TIMEOUT=4s
REDIS_CONN_MAX_IDLE_TIME=30m

# 是否启用 Redis（false 时禁用 token 黑名单、限流等功能）
REDIS_ENABLED=true

#------------------------------------------------------------------------------
# JWT 配置
#------------------------------------------------------------------------------
# 签名密钥（生产环境必须修改，至少 32 字节）
JWT_SIGNING_KEY=change-me-in-production-must-be-at-least-32-bytes-long

# 签名算法：HS256, HS384, HS512, RS256, RS384, RS512, ES256, ES384, ES512
JWT_SIGNING_METHOD=HS256

# Token 过期时间
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=168h  # 7 days

# Issuer
JWT_ISSUER=traffic-analysis-platform

# Audience（逗号分隔）
JWT_AUDIENCE=traffic-api,traffic-ui

# 时钟偏移容忍度
JWT_CLOCK_SKEW=30s

# RSA/ECDSA 密钥文件（仅当使用非对称算法时）
# JWT_PRIVATE_KEY_FILE=/path/to/private.key
# JWT_PUBLIC_KEY_FILE=/path/to/public.key

#------------------------------------------------------------------------------
# OIDC 配置（可选）
#------------------------------------------------------------------------------
OIDC_ENABLED=false
OIDC_ISSUER_URL=https://your-oidc-provider.com
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
OIDC_REDIRECT_URL=https://your-app.com/auth/callback
OIDC_SCOPES=openid,profile,email

#------------------------------------------------------------------------------
# Token 配置
#------------------------------------------------------------------------------
# 每个租户最大 Token 数量
TOKEN_MAX_TOKENS_PER_TENANT=100

# 默认 Token 过期时间（0 表示永不过期）
TOKEN_DEFAULT_TTL=8760h  # 365 days

# Token 类型启用开关
TOKEN_ENABLE_USER_TOKENS=true
TOKEN_ENABLE_API_TOKENS=true
TOKEN_ENABLE_PROBE_TOKENS=true

# Token 轮转
TOKEN_ENABLE_ROTATION=false
TOKEN_ROTATION_INTERVAL=720h  # 30 days
TOKEN_ROTATION_GRACE_PERIOD=168h  # 7 days

#------------------------------------------------------------------------------
# 审计日志配置
#------------------------------------------------------------------------------
AUDIT_ENABLED=true
AUDIT_TOPIC=audit.logs
AUDIT_BUFFER_SIZE=1000
AUDIT_BATCH_SIZE=100
AUDIT_FLUSH_INTERVAL=1s

# 本地备份配置
AUDIT_BACKUP_ENABLED=true
AUDIT_BACKUP_DIR=/var/log/audit

#------------------------------------------------------------------------------
# Kafka 配置
#------------------------------------------------------------------------------
KAFKA_BROKERS=localhost:9092

#------------------------------------------------------------------------------
# API 配置
#------------------------------------------------------------------------------
# CORS 允许的来源（逗号分隔）
API_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# 请求速率限制
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_RPS=100

# 最大请求体大小
API_MAX_REQUEST_BODY_SIZE=1048576  # 1MB

#------------------------------------------------------------------------------
# OpenTelemetry 配置
#------------------------------------------------------------------------------
OTEL_ENABLED=true
OTEL_SERVICE_NAME=auth-service
OTEL_SERVICE_VERSION=1.0.0
OTEL_ENVIRONMENT=development
OTEL_ENDPOINT=localhost:4317
OTEL_INSECURE=true
OTEL_SAMPLE_RATE=1.0

#------------------------------------------------------------------------------
# 安全配置
#------------------------------------------------------------------------------
# 密码策略
SECURITY_MIN_PASSWORD_LENGTH=12
SECURITY_REQUIRE_UPPERCASE=true
SECURITY_REQUIRE_LOWERCASE=true
SECURITY_REQUIRE_DIGIT=true
SECURITY_REQUIRE_SPECIAL=true

# Bcrypt cost (10-12 推荐)
SECURITY_BCRYPT_COST=12

# 登录失败锁定
SECURITY_MAX_LOGIN_ATTEMPTS=5
SECURITY_LOCKOUT_DURATION=15m

# Session 配置
SECURITY_SESSION_TIMEOUT=24h
SECURITY_SESSION_REFRESH_WINDOW=1h