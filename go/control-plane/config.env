# ////////////////////////////////////////////////////////////////////////////////
# // FILE PATH: control-plane/config.env
# ////////////////////////////////////////////////////////////////////////////////
# ==================== 环境配置 ====================
export ENVIRONMENT=development  # development, staging, production

# ==================== Kafka Configuration ====================
export KAFKA_BROKERS=localhost:9093
export KAFKA_FLOW_TOPIC=flow.events.v1
export KAFKA_PCAP_TOPIC=pcap.index.v1
export KAFKA_SESSION_TOPIC=session.events.v1
export KAFKA_DLQ_TOPIC=dlq.ingest-gateway
export KAFKA_BATCH_SIZE=1000
export KAFKA_BATCH_TIMEOUT=100ms
export KAFKA_COMPRESSION=lz4
export KAFKA_REQUIRED_ACKS=all
export KAFKA_ENABLE_IDEMPOTENCE=true
export KAFKA_MAX_RETRIES=3

# ==================== Redis Configuration ====================
export REDIS_ADDRS=localhost:6379
export REDIS_PASSWORD=
export REDIS_DB=0
export REDIS_POOL_SIZE=100
export REDIS_MIN_IDLE_CONNS=10
export REDIS_DIAL_TIMEOUT=5s
export REDIS_READ_TIMEOUT=3s
export REDIS_WRITE_TIMEOUT=3s
export REDIS_POOL_TIMEOUT=4s
export REDIS_CONN_MAX_IDLE_TIME=30m

# ==================== PostgreSQL Configuration ====================
export POSTGRES_DSN="postgres://traffic:traffic123@localhost:5432/traffic_control?sslmode=disable"
export POSTGRES_MAX_OPEN_CONNS=10
export POSTGRES_MAX_IDLE_CONNS=5
export POSTGRES_CONN_LIFETIME=1h

# ==================== Server Configuration ====================
export GRPC_ADDR=:50051
export HTTP_ADDR=:8080
export HEALTH_ADDR=:8081
export METRICS_ADDR=:9090
export GRPC_MAX_RECV_MSG_SIZE=67108864  # 64MB
export GRPC_MAX_SEND_MSG_SIZE=67108864
export GRPC_KEEPALIVE_TIME=2m
export GRPC_KEEPALIVE_TIMEOUT=10s
export GRPC_MAX_CONNECTION_IDLE=10m
export GRPC_MAX_CONNECTION_AGE=30m
export GRPC_MAX_CONNECTION_AGE_GRACE=5m

# ==================== TLS Configuration (可选) ====================
export TLS_CERT_FILE=./certs/server/server-cert.pem
export TLS_KEY_FILE=./certs/server/server-key.pem
export TLS_CA_FILE=./certs/ca/ca-cert.pem

# ==================== Authentication ====================
export REQUIRE_MTLS=true
export ALLOW_NO_TOKEN=false
export DEFAULT_TENANT_ID=default
export TOKEN_TTL=5m
export LOCAL_CACHE_TTL=30s
export LOCAL_CACHE_SIZE=10000

# ==================== Authorization ====================
export REQUIRE_SCOPES=true
export REQUIRED_SCOPES=ingest:write
export ENABLE_AUDIT=true
export ENABLE_PROBE_RBAC=true

# ==================== Rate Limiting ====================
export RATE_LIMIT_REDIS_ENABLED=true
export RATE_LIMIT_REDIS_PREFIX=ratelimit:
export RATE_LIMIT_GLOBAL_RPS=100000
export RATE_LIMIT_GLOBAL_BURST=200000
export RATE_LIMIT_TENANT_RPS=10000
export RATE_LIMIT_TENANT_BURST=20000
export RATE_LIMIT_PROBE_RPS=5000
export RATE_LIMIT_PROBE_BURST=10000
export RATE_LIMIT_LOCAL_FALLBACK=true

# ==================== Deduplication ====================
export DEDUP_ENABLED=true
export DEDUP_LOCAL_CACHE_SIZE=100000
export DEDUP_LOCAL_TTL=5m
export DEDUP_REDIS_ENABLED=false
export DEDUP_REDIS_PREFIX=dedup:
export DEDUP_REDIS_TTL=10m

# ==================== Handler Configuration ====================
export MAX_BATCH_SIZE=10000
export MAX_EVENT_SIZE=65536  # 64KB
export STREAM_BUFFER_SIZE=1000
export HEARTBEAT_INTERVAL=30s
export ENABLE_DLQ=true
export ENABLE_DEDUP=true
export PROBE_STATUS_TIMEOUT=5m

# ==================== Probe Configuration ====================
export PROBE_DEFAULT_SAMPLE_RATE=1.0
export PROBE_DEFAULT_IDLE_TIMEOUT=60s
export PROBE_DEFAULT_ACTIVE_TIMEOUT=300s
export PROBE_DEFAULT_BATCH_SIZE=1000
export PROBE_DEFAULT_BPF_FILTER=
export PROBE_CONFIG_REFRESH_INTERVAL=1m
export PROBE_ENABLE_DYNAMIC_CONFIG=true
export PROBE_STATUS_CLEANUP_INTERVAL=1m

# ==================== DLQ Configuration ====================
export DLQ_FALLBACK_DIR=/tmp/ingest-dlq-fallback
export DLQ_MAX_FALLBACK_SIZE=104857600  # 100MB
export DLQ_REPLAY_INTERVAL=5m
export DLQ_REPLAY_BATCH_SIZE=1000
export DLQ_REPLAY_SUCCESS_RATE_MIN=0.5

# ==================== Audit Configuration ====================
export AUDIT_ENABLED=true
export AUDIT_TOPIC=audit.logs
export AUDIT_BUFFER_SIZE=1000
export AUDIT_BATCH_SIZE=100
export AUDIT_FLUSH_INTERVAL=1s

# ==================== Feature Set ====================
export DEFAULT_FEATURE_SET_ID=v1

# ==================== Logging ====================
export LOG_LEVEL=info  # debug, info, warn, error

# ==================== Metrics ====================
export METRICS_ENABLED=true

# ==================== JWT Configuration ====================
export JWT_SIGNING_KEY="OpgtDGF8lqETksFD3768dmQ1cGEJIf1u/W12/ekrWsE="
export JWT_SIGNING_METHOD=HS256
export JWT_ACCESS_TOKEN_TTL=15m
export JWT_REFRESH_TOKEN_TTL=168h  # 7 days
export JWT_ISSUER=traffic-auth-service

# ==================== OIDC Configuration (可选) ====================
export OIDC_ENABLED=false
# export OIDC_ISSUER_URL=https://auth.example.com
# export OIDC_CLIENT_ID=traffic-platform
# export OIDC_CLIENT_SECRET=secret
# export OIDC_REDIRECT_URL=http://localhost:8080/auth/callback
# export OIDC_SCOPES="openid profile email"

# ==================== Token Management ====================
export MAX_TOKENS_PER_TENANT=100
export DEFAULT_TOKEN_TTL=8760h  # 1 year

# ==================== HTTP Configuration ====================
export HTTP_ENABLED=true
export HTTP_READ_TIMEOUT=30s
export HTTP_WRITE_TIMEOUT=30s
export HTTP_IDLE_TIMEOUT=120s
export HTTP_ALLOWED_ORIGINS=*
export HTTP_ALLOWED_METHODS="GET,POST,PUT,DELETE,OPTIONS"

# ==================== API Configuration ====================
export API_LISTEN_ADDR=:8080
export API_READ_TIMEOUT=30s
export API_WRITE_TIMEOUT=30s
export API_IDLE_TIMEOUT=120s
export API_ALLOWED_ORIGINS=*


# ==================== 注意事项 ====================
# 1. 生产环境必须修改 JWT_SIGNING_KEY
# 2. 生产环境建议启用 REQUIRE_MTLS=true
# 3. 确保 config.env 文件权限为 600 (chmod 600 config.env)
# 4. 敏感信息（密码、密钥）不要提交到版本控制系统
# 5. 不同环境使用不同的配置文件（config.dev.env, config.prod.env）