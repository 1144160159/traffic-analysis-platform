# =========================
# Stage 1: Builder
# =========================
FROM openeuler/openeuler:22.03-lts as builder

# 安装构建工具
RUN dnf update -y && \
    dnf groupinstall -y "Development Tools" && \
    dnf install -y \
        clang \
        llvm \
        lld \
        elfutils-libelf-devel \
        zlib-devel \
        openssl-devel \
        kernel-devel \
        pkg-config \
        git \
        protobuf-compiler \
        protobuf-devel && \
    dnf clean all

# 安装 Rust
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain 1.75.0
ENV PATH="/root/.cargo/bin:${PATH}"

# 设置工作目录
WORKDIR /workspace

# 复制项目文件
COPY rust/probe-agent /workspace/

# 构建项目
RUN cargo build --release --target x86_64-unknown-linux-gnu

# =========================
# Stage 2: Runtime
# =========================
FROM openeuler/openeuler:22.03-lts

RUN dnf install -y \
        libelf \
        openssl \
        ca-certificates \
        zstd && \
    dnf clean all

# 创建运行用户
RUN useradd -r -s /bin/false probe

# 创建必要目录
RUN mkdir -p /var/lib/probe-agent/cache && \
    chown -R probe:probe /var/lib/probe-agent

# 复制二进制文件
COPY --from=builder /workspace/target/x86_64-unknown-linux-gnu/release/probe-agent /usr/local/bin/

# 切换用户
USER probe

ENTRYPOINT ["/usr/local/bin/probe-agent"]